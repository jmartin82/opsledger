# Container registry and image tag
# Example: IMAGE_REGISTRY=ghcr.io/youruser
IMAGE_REGISTRY=ghcr.io/youruser
IMAGE_TAG=latest

# UI port exposed on the host
UI_PORT=80

# Database configuration
DB_NAME=ops_ledger
DB_USER=tracker
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme_root

# Backend configuration
JWT_SECRET=change-this-to-a-long-random-secret
